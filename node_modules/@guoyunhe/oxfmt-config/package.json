{
  "name": "@guoyunhe/oxfmt-config",
  "version": "1.1.0",
  "description": "A shared configuration for oxfmt by Guo Yunhe.",
  "keywords": [
    "code-formatting",
    "code-style",
    "eslint",
    "format",
    "lint",
    "oxfmt",
    "oxfmt-config",
    "prettier",
    "prettier-config",
    "shared-config",
    "typescript"
  ],
  "homepage": "https://github.com/guoyunhe/oxfmt-config#readme",
  "bugs": {
    "url": "https://github.com/guoyunhe/oxfmt-config/issues"
  },
  "license": "MPL-2.0",
  "author": {
    "name": "Guo Yunhe",
    "email": "i@guoyunhe.me",
    "url": "https://guoyunhe.me"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/guoyunhe/oxfmt-config.git"
  },
  "funding": "https://github.com/sponsors/guoyunhe",
  "files": [
    "dist",
    "CHANGELOG.md",
    "LICENSE",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@mdx-js/react": "^3.1.1",
    "@types/node": "^22.19.17",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "eslint": "^9.39.4",
    "eslint-config-ali": "^16.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.45.0",
    "prettier": "^3.8.3",
    "prettier-config-ali": "^1.5.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "rive": "^3.4.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "lint-staged": {
    "*.{cjs,cts,js,jsx,mjs,mts,ts,tsx,vue}": "eslint --fix",
    "*.{cjs,css,cts,html,js,json,jsx,less,md,mjs,mts,scss,ts,tsx,vue,yaml,yml}": "prettier --write"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "prettier": "prettier-config-ali",
  "rive": {
    "template": "node",
    "doc": {
      "basename": "/oxfmt-config/"
    }
  },
  "scripts": {
    "build": "rive build",
    "build:watch": "rive build --watch",
    "ci:eslint": "eslint -f json src -o ./.ci/eslint.json",
    "lint": "eslint .",
    "lint:fix": "prettier --write . && eslint --fix .",
    "format": "oxfmt .",
    "start": "rive start",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:watch": "vitest"
  }
}